NODE_ENV=development
PORT=3000

MONGO_URI=mongodb://127.0.0.1:27017/decizhen
MONGO_DB_NAME=decizhen

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DISABLED=false

ALLOWED_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
GEOCODE_CACHE_TTL_SECONDS=3600
PRESENCE_TTL_SECONDS=60

SEARCH_ANALYTICS_BUCKET_SECONDS=900
SEARCH_ANALYTICS_DEDUPE_TTL_SECONDS=1020
ANALYTICS_HASH_SALT=

JWT_SECRET=your_jwt_secret_here

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ENABLE_CLOUDINARY=false

FRONTEND_URL=http://localhost:3000
TRUST_PROXY=0
PRIVACY_POLICY_VERSION=2026-02-18
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_PATH=/auth/reset-password
PASSWORD_RESET_RETURN_LINK=false
PASSWORD_RESET_EMAIL_MODE=disabled
PASSWORD_RESET_EMAIL_WEBHOOK_URL=
PASSWORD_RESET_EMAIL_WEBHOOK_BEARER=
PASSWORD_RESET_EMAIL_FROM=noreply@example.com
PASSWORD_RESET_EMAIL_FROM_NAME=De'ciZhen
PASSWORD_RESET_EMAIL_SUBJECT=Reset your De'ciZhen password
PASSWORD_RESET_BREVO_API_URL=https://api.brevo.com/v3/smtp/email
PASSWORD_RESET_BREVO_API_KEY=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/auth/oauth/google/callback

APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_REDIRECT_URI=http://localhost:4000/auth/oauth/apple/callback
